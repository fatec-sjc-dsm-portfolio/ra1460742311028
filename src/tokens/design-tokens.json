{
  "color": {
    "bg":     { "base": "#0A0B0D", "elevated": "#101216", "surface": "#16191F", "overlay": "rgba(10,11,13,0.72)" },
    "fg":     { "primary": "#F2F4F7", "secondary": "#A8B0BD", "muted": "#6B7280", "inverse": "#0A0B0D" },
    "border": { "subtle": "rgba(255,255,255,0.06)", "strong": "rgba(255,255,255,0.14)" },
    "accent": { "primary": "#3B82F6", "primaryHi": "#60A5FA", "glow": "rgba(59,130,246,0.35)" },
    "semantic": { "success": "#10B981", "warning": "#F59E0B", "danger": "#EF4444" }
  },
  "font": {
    "family": {
      "sans": "'Inter', system-ui, -apple-system, sans-serif",
      "mono": "'JetBrains Mono', ui-monospace, Menlo, monospace"
    },
    "size": {
      "xs": "0.75rem", "sm": "0.875rem", "base": "1rem", "lg": "1.125rem",
      "xl": "1.5rem", "2xl": "2.25rem", "3xl": "3.5rem",
      "display": "clamp(3rem, 8vw, 7rem)"
    },
    "weight":   { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 },
    "leading":  { "tight": 1.1, "snug": 1.3, "normal": 1.5 },
    "tracking": { "tight": "-0.02em", "wide": "0.08em" }
  },
  "space": {
    "1": "0.25rem", "2": "0.5rem", "3": "0.75rem", "4": "1rem",
    "6": "1.5rem", "8": "2rem", "12": "3rem",
    "16": "4rem", "24": "6rem", "32": "8rem"
  },
  "radius": { "sm": "4px", "md": "8px", "lg": "16px", "xl": "24px", "pill": "999px" },
  "shadow": {
    "sm":   "0 1px 2px rgba(0,0,0,0.4)",
    "md":   "0 8px 24px rgba(0,0,0,0.5)",
    "glow": "0 0 32px rgba(59,130,246,0.25)"
  },
  "motion": {
    "duration": { "fast": "0.2s", "base": "0.4s", "slow": "0.8s", "scene": "1.2s" },
    "ease":     { "out": "cubic-bezier(0.16,1,0.3,1)", "inOut": "cubic-bezier(0.65,0,0.35,1)", "expo": "expo.out", "power3": "power3.out" }
  },
  "layout": { "maxWidth": "1280px", "gutter": "clamp(1rem, 4vw, 3rem)" }
}
